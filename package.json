{
  "name": "sidecamp",
  "private": true,
  "version": "0.5.1",
  "description": "Desktop companion app for TuneCamp — P2P content acquisition and peer file sharing.",
  "author": {
    "name": "scobru",
    "email": "scobru@users.noreply.github.com"
  },
  "desktopName": "Sidecamp",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "node patch_script.cjs",
    "dev": "vite",
    "compile": "tsc -b && vite build",
    "build": "npm run compile && electron-builder",
    "build:win": "npm run compile && electron-builder --win",
    "build:mac": "npm run compile && electron-builder --mac",
    "build:linux": "npm run compile && electron-builder --linux",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/ws": "^8.18.1",
    "andrade-soulseek-downloader": "^1.0.28",
    "axios": "^1.18.1",
    "form-data": "^4.0.6",
    "fs-extra": "^11.3.6",
    "lucide-react": "^1.23.0",
    "music-metadata": "^11.13.0",
    "node-id3": "^0.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "slsk-client": "^1.1.0",
    "socket.io-client": "^4.8.3",
    "webtorrent": "^3.0.16",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.sidecamp.app",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "icon": "src/assets/logo.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "scobru <scobru@users.noreply.github.com>",
      "synopsis": "P2P content acquisition and peer file sharing"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
